APP_NAME="Virtual Pet Care"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────
# SQLite (default, zero setup):
DB_CONNECTION=sqlite

# MySQL (Local Development):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=virtual_pet_care
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL (Production Cloud: Render, Neon, Supabase):
# DB_CONNECTION=pgsql
# DB_HOST=ep-cool-butterfly-12345.us-east-2.aws.neon.tech
# DB_PORT=5432
# DB_DATABASE=neondb
# DB_USERNAME=alex
# DB_PASSWORD=your_password
# DB_SSLMODE=require

# MySQL (Production Cloud: Aiven, TiDB Cloud):
# DB_CONNECTION=mysql
# DB_HOST=mysql-your-project.aivencloud.com
# DB_PORT=3306
# DB_DATABASE=defaultdb
# DB_USERNAME=avnadmin
# DB_PASSWORD=your_password
# MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt


# ─── Session ─────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Broadcasting ────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ─── Filesystem ──────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── Queue ───────────────────────────────────────────────────────
# 'sync' for local dev, 'database' or 'redis' for production
QUEUE_CONNECTION=sync

# ─── Cache ───────────────────────────────────────────────────────
CACHE_STORE=database

# ─── Mail ────────────────────────────────────────────────────────
# Use MAIL_MAILER=log for local dev (no real emails sent)
# Use MAIL_MAILER=smtp with Gmail App Password for real emails
MAIL_MAILER=log
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── Redis (optional) ────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── AWS (not used by default) ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
